# DATABASE_URL — required for Drizzle ORM (lib/db/index.ts).
#
# Dev mode (npm run dev on the host):
#   Use localhost if Postgres is running locally or via `docker compose up -d postgres`.
#   The docker-compose.yml postgres service exposes port 5433 on the host (the container
#   still listens on 5432 internally). This avoids collisions with a native Postgres install.
#
# Production mode (docker compose up):
#   The app container receives its DATABASE_URL automatically from docker-compose.yml
#   (pointing at the `postgres` service name, not localhost). This value is only used
#   for dev-on-host workflows.
DATABASE_URL=postgresql://merkle:merkle_dev@localhost:5433/merkle

# MCP endpoint URL — agents and the browser-side frontend read this at startup.
# Local dev: leave as-is. After deployment: replace with your deployed URL.
# Change here without touching code or redeploying agents.
# NEXT_PUBLIC_ prefix required: Next.js only exposes env vars with this prefix to the browser bundle.
NEXT_PUBLIC_MCP_URL=http://localhost:7423/api/mcp

# Future use — placeholder for connection-level auth (post-MVP).
MCP_SESSION_TOKEN_SECRET=

# RUN_DB_MIGRATIONS — when "true", instrumentation.ts applies pending Drizzle
# migrations on server startup (before serving traffic). The Docker image sets
# this to true so deploys are auto-migrating; leave unset/false for `npm run dev`.
RUN_DB_MIGRATIONS=false
